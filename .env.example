# ---- Anthropic / AI ----
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL_ID=claude-sonnet-4-6
AI_EFFORT=medium                 # low | medium | high | max

# ---- Postgres (source & analytics) ----
SOURCE_DB_USER=finance
SOURCE_DB_PASSWORD=changeme
SOURCE_DB_NAME=source
ANALYTICS_DB_USER=analytics
ANALYTICS_DB_PASSWORD=changeme
ANALYTICS_DB_NAME=analytics

# ---- Servis URL'leri ----
AI_ENGINE_URL=http://ai-engine:8000
SUPERSET_URL=http://superset:8088

# ---- Superset ----
SUPERSET_SECRET_KEY=changeme
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin

# ---- Observability ----
# Collector is part of the stack; api/ai-engine default to it. Leave empty to
# disable trace export (spans still created, just not sent anywhere).
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
